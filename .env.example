# Claudio 配置文件
# 复制此文件为 .env 并填写您的配置

# 服务端口
PORT=8080

# DeepSeek API配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 火山引擎TTS配置
VOLCANO_TTS_APPID=your_volcano_appid_here
VOLCANO_TTS_ACCESS_TOKEN=your_volcano_access_token_here
VOLCANO_TTS_CLUSTER=volcano_tts
VOLCANO_TTS_VOICE_NAME=zh_female_shuangkuaisisi_moon_bigtts

# 网易云音乐配置 (可选，用于获取更高音质)
# 登录后从浏览器开发者工具获取Cookie
NCM_COOKIE=your_netease_cloud_music_cookie_here

# 天气API (可选，使用wttr.in无需配置)
WEATHER_CITY=Beijing

# 调试模式
DEBUG=false
